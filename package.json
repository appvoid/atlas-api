{
  "name": "atlas",
  "version": "1.0.0",
  "description": "API de clasificacion y gestion de tickets con Express, SQLite y CrispEmbed.",
  "private": true,
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "test": "tsx --test tests/**/*.test.ts",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "build": "tsc --project tsconfig.json",
    "build:crispembed": "tsx scripts/build-crispembed.ts"
  },
  "dependencies": {
    "express": "^4.21.2",
    "tsx": "^4.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
